# Production environment configuration
# Place this at the project root as: .env.production
# This file contains secrets. DO NOT commit .env.production to git.

# ============================================================
# Odoo (production database)
# ============================================================
ODOO_URL=https://suncompany.odoo.com
ODOO_DB=suncompany
ODOO_USERNAME=REPLACE_WITH_YOUR_LOGIN_EMAIL
ODOO_API_KEY=REPLACE_WITH_PRODUCTION_API_KEY

# ============================================================
# SendGrid
# ============================================================
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_API_KEY
EMAIL_FROM=REPLACE_WITH_VERIFIED_SENDGRID_SENDER
EMAIL_TO=dcross@suncompany.com

# ============================================================
# Webhook
# ============================================================
# The base URL of the FastAPI webhook deployed to Render.
# Used to build "Create Draft PO" links in the digest emails.
WEBHOOK_BASE_URL=https://odoo-replenishment-webhook.onrender.com

# Shared secret used to sign PO-creation tokens embedded in email links.
# Set this to a long random string. Must match the value on the Render service.
WEBHOOK_SHARED_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# ============================================================
# Replenishment configuration
# ============================================================
# Date Odoo went live for sales tracking.
# Sales orders on/after this date are pulled from Odoo;
# anything before is sourced from the Sage history file.
ODOO_CUTOVER_DATE=2026-05-01

# Buffer months added on top of vendor lead time for the urgent trigger.
URGENT_BUFFER_MONTHS=2

# Buffer months for the add-on suggestion tier.
ADDON_BUFFER_MONTHS=4

# Low-stock catchall threshold (forecasted qty).
LOW_STOCK_THRESHOLD=500
